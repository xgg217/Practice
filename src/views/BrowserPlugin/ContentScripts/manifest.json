{
  "manifest_version": 3,
  "name": "浏览器插件开发",
  "version": "0.0.1",
  "description": "浏览器开发快速开发",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "hello.html",
    "default_icon": "images/icon-16.png"
  },
  "content_scripts": [
    {
      "js": [
        "scripts/content.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_end"
    }
  ]
}